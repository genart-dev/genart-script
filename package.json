{
  "name": "@genart-dev/genart-script",
  "version": "0.1.2",
  "description": "Compiler and runtime for the GenArt Script language (.genart-script / .gs)",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./runtime": {
      "import": {
        "types": "./dist/runtime.d.ts",
        "default": "./dist/runtime.js"
      },
      "require": {
        "types": "./dist/runtime.d.cts",
        "default": "./dist/runtime.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "author": {
    "name": "genart.dev",
    "email": "support@genart.dev",
    "url": "https://genart.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/genart-dev/genart-script.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "postbuild": "node -e \"const fs=require('fs'); ['dist/index.d.ts','dist/runtime.d.ts'].forEach(f=>{if(!fs.existsSync(f)){console.error('ERROR: '+f+' missing');process.exit(1)}});console.log('Verified: DTS files present')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
